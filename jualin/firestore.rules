rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    // Cek apakah user sudah login (custom token atau anonymous)
    function isSignedIn() {
      return request.auth != null;
    }

    // Cek apakah User yang request adalah pemilik data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- RULES ---

    // 1. Collection Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId);
    }

    // 2. Collection Chats (Room Chat)
    // Note: participants berisi Laravel user ID (string), bukan Firebase UID.
    // Kita relaksasi rule agar authenticated user (termasuk anonymous) bisa akses,
    // karena ID tracking dilakukan di level aplikasi.
    match /chats/{chatId} {
      // Read: Hanya boleh baca jika user sudah login (auth dilakukan di app level)
      allow read: if isSignedIn();
      
      // Create: Boleh buat chat baru asal sudah login
      allow create: if isSignedIn();
      
      // Update: Boleh update jika sudah login (misal: update last_message, unread count)
      allow update: if isSignedIn();

      // 3. Sub-collection Messages
      match /messages/{messageId} {
        // Read & List: Hanya user yang sudah login
        allow read, list: if isSignedIn();
        
        // Create: User harus sudah login
        allow create: if isSignedIn();
        
        // Update: tidak diperbolehkan dari client (hanya server)
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
